# Copy to .env and fill in your values:
#   copy .env.example .env

OPENAI_API_KEY=
OPENAI_INSECURE_TLS=0
GOOGLE_API_KEY=

# LLM vendor: openai | gemini
LLM_VENDOR=gemini
LLM_VENDOR_PRIMARY=gemini
LLM_VENDOR_FALLBACK=openai
LLM_VENDOR_FALLBACK_ENABLED=1

OPENAI_EMAIL_SUMMARY_MODEL=gpt-4.1-mini
GEMINI_SUMMARY_MODEL=gemini-2.5-flash-lite
GEMINI_LITE_MODEL=gemini-2.5-flash-lite
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_TOP_NEWS_RANK_MODEL=gemini-2.5-flash
OPENAI_TOP_NEWS_RANK_MODEL=gpt-4.1

GEMINI_GROUNDING=1
GEMINI_CALL_DELAY_SECONDS=5
GEMINI_RETRY_DELAY_SECONDS=5
GEMINI_MAX_RETRY_ATTEMPTS=2
GEMINI_LITE_MAX_503_BEFORE_FLASH=5
GEMINI_FLASH_MAX_503_BEFORE_OPENAI=5

DAILY_EMAIL_RETRY_DELAY_SECONDS=600
DAILY_EMAIL_MAX_ATTEMPTS=3

# Network: AUTO_HTTP_PROXY=1 uses corp proxy when genproxy resolves; empty forces direct
AUTO_HTTP_PROXY=1
# HTTP_PROXY=
# HTTPS_PROXY=

# Email delivery: outlook | gmail
EMAIL_SEND_PROVIDER=gmail
EMAIL_SEND_FALLBACK_PROVIDER=outlook
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_TO=you@gmail.com
GMAIL_SELF_ONLY=1

# Outlook MCP (required when EMAIL_SEND_PROVIDER=outlook)
# OUTLOOK_MCP_DIR=C:\path\to\outlook-mcp-server-v4

# Daily news recipients
DAILY_NEWS_RECIPIENT=you@example.com
DAILY_TECH_NEWS_RECIPIENT=you@example.com
DAILY_TOP_NEWS_RECIPIENT=you@example.com

# AI Trainer (daily hands-on exercise email)
AI_TRAINER_VENDOR=openai
AI_TRAINER_MODEL=gpt-4.1
AI_TRAINER_TO=you@example.com
AI_TRAINER_BCC=
AI_TRAINER_INCLUDE_HISTORY_IN_EMAIL=1
AI_TRAINER_HISTORY_IN_EMAIL_MAX=5
AI_TRAINER_GROUNDING=1

# Job Search (default profile — or use data/job_profiles/*.json)
JOB_SEARCH_CV_DOCX=data/cv.docx
JOB_SEARCH_CV_PATH=data/job_search_cv.md
JOB_SEARCH_SYNC_MD_FROM_DOCX=1
JOB_SEARCH_HOME_LOCATION=Your City, Israel
JOB_SEARCH_TO=you@example.com
JOB_SEARCH_HISTORY_FILE=data/job_search_history.md
JOB_SEARCH_KEYWORDS=solution architect, senior developer, hi-tech
JOB_SEARCH_FOCUS=hitech
JOB_SEARCH_HITECH_BOARDS=1
JOB_SEARCH_VENDOR=gemini
JOB_SEARCH_VENDOR_FALLBACK=openai
JOB_SEARCH_VENDOR_FALLBACK_ENABLED=1
JOB_SEARCH_MODEL=gemini-2.5-flash
JOB_SEARCH_OPENAI_MODEL=gpt-4.1-mini
JOB_SEARCH_OPENAI_WEB_MODEL=gpt-4.1-mini
JOB_SEARCH_USE_OPENAI_WEB=1
JOB_SEARCH_GROUNDING=1
JOB_SEARCH_LINKEDIN=1
JOB_SEARCH_MAX_JOBS=15
JOB_SEARCH_MAX_TOKENS=8192
JOB_SEARCH_LOCATIONS=Jerusalem, Hybrid, Remote
JOB_SEARCH_CANDIDATE_NAME=Your Name
JOB_SEARCH_CANDIDATE_EMAIL=you@example.com
JOB_SEARCH_CANDIDATE_PHONE=
JOB_SEARCH_OPENAI_CHAT_FALLBACK=0

# Block PA / Gaza / West Bank job locations (set JOB_SEARCH_ALLOW_PA_LOCATIONS=1 to allow)
# JOB_SEARCH_LOCATION_BLOCKLIST=
